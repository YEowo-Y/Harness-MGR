{
  "name": "claude-mgr-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Localhost-only, read-only web UI for claude-mgr (P0). Surfaces the zero-dep engine (src/cli/commands.mjs) over a 127.0.0.1 Hono API. Isolated from the CLI core so the core stays zero-runtime-dependency (mirrors the tui/ Go module).",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/server.mjs",
    "dev:web": "vite",
    "build": "vite build",
    "start": "node server/server.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "hono": "^4.6.14",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
