{
  "name": "harness-mgr-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Localhost-only web UI for harness-mgr. Surfaces the zero-dep engine (src/cli/commands.mjs) over a 127.0.0.1 Hono API — reads plus a frozen set of gated, reversible writes. Isolated from the CLI core so the core stays zero-runtime-dependency (mirrors the tui/ Go module).",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/server.mjs",
    "dev:web": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "node server/server.mjs",
    "preview": "vite preview",
    "test": "vitest run && node --test server/*.test.mjs",
    "test:client": "vitest run",
    "test:server": "node --test server/*.test.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "hono": "^4.6.14",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  }
}
