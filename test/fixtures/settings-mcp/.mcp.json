{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp"
    },
    "secret-svc": {
      "command": "node",
      "args": ["server.js"],
      "env": {
        "SECRET_SVC_API_KEY": "APIKEY_MUSTNOTLEAK",
        "SECRET_SVC_REGION": "REGION_MUSTNOTLEAK"
      }
    }
  }
}
